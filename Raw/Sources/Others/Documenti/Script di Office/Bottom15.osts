{"version":"0.3.0","body":"function main(workbook: ExcelScript.Workbook) {\r\n\tlet selectedSheet = workbook.getActiveWorksheet();\r\n\t// Toggle auto filter on selectedSheet\r\n\tselectedSheet.getAutoFilter().apply(selectedSheet.getRange(\"J1\"));\r\n\t// Apply custom filter on selectedSheet\r\n\tselectedSheet.getAutoFilter().apply(selectedSheet.getAutoFilter().getRange(), 9, { filterOn: ExcelScript.FilterOn.custom, criterion1: \">=170\" });\r\n\t// Set visibility of column(s) at range J1 on selectedSheet to true\r\n\tselectedSheet.getRange(\"J1\").setColumnHidden(true);\r\n\t// Set visibility of column(s) at range B:B on selectedSheet to true\r\n\tselectedSheet.getRange(\"B:B\").setColumnHidden(true);\r\n\t// Set visibility of column(s) at range F:F on selectedSheet to true\r\n\tselectedSheet.getRange(\"F:F\").setColumnHidden(true);\r\n\t// Set visibility of column(s) at range G:G on selectedSheet to true\r\n\tselectedSheet.getRange(\"G:G\").setColumnHidden(true);\r\n\t// Set visibility of column(s) at range H:H on selectedSheet to true\r\n\tselectedSheet.getRange(\"H:H\").setColumnHidden(true);\r\n\t// Set visibility of column(s) at range I:I on selectedSheet to true\r\n\tselectedSheet.getRange(\"I:I\").setColumnHidden(true);\r\n\t// Set visibility of column(s) at range J:J on selectedSheet to true\r\n\tselectedSheet.getRange(\"J:J\").setColumnHidden(true);\r\n\t// Set fill color to #76933C for range A1:E1 on selectedSheet\r\n\tselectedSheet.getRange(\"A1:E1\").getFormat().getFill().setColor(\"#76933C\");\r\n\t// Set range A1 on selectedSheet\r\n\tselectedSheet.getRange(\"A1\").setValue(\"Bottom 15 Stores\");\r\n}","description":"","noCodeMetadata":"{\"intents\":[\"Toggle AutoFilter on worksheet Sales\",\"Apply custom filter to A1:J185\",\"Hide column(s) on J1\",\"Hide column(s) on B:B\",\"Hide column(s) on F:F\",\"Hide column(s) on G:G\",\"Hide column(s) on H:H\",\"Hide column(s) on I:I\",\"Hide column(s) on J:J\",\"Set background color to #76933C on A1:E1\",\"Set cell A1 to Bottom 15 Stores\"]}","parameterInfo":null,"apiInfo":"{\"variant\":\"synchronous\",\"variantVersion\":2}"}