{"version":"0.3.0","body":"function main(workbook: ExcelScript.Workbook) {\r\n\tlet selectedSheet = workbook.getActiveWorksheet();\r\n\t// Set visibility of column(s) at range J:J on selectedSheet to false\r\n\tselectedSheet.getRange(\"J:J\").setColumnHidden(false);\r\n\t// Set visibility of column(s) at range B:B on selectedSheet to false\r\n\tselectedSheet.getRange(\"B:B\").setColumnHidden(false);\r\n\t// Set visibility of column(s) at range E:E on selectedSheet to false\r\n\tselectedSheet.getRange(\"E:E\").setColumnHidden(false);\r\n\t// Set visibility of column(s) at range I:I on selectedSheet to false\r\n\tselectedSheet.getRange(\"I:I\").setColumnHidden(false);\r\n\t// Set visibility of column(s) at range H:H on selectedSheet to false\r\n\tselectedSheet.getRange(\"H:H\").setColumnHidden(false);\r\n\t// Set visibility of column(s) at range G:G on selectedSheet to false\r\n\tselectedSheet.getRange(\"G:G\").setColumnHidden(false);\r\n\t// Set visibility of column(s) at range G:G on selectedSheet to false\r\n\tselectedSheet.getRange(\"G:G\").setColumnHidden(false);\r\n\t// Set visibility of column(s) at range E:E on selectedSheet to false\r\n\tselectedSheet.getRange(\"E:E\").setColumnHidden(false);\r\n\t// Set visibility of column(s) at range F:F on selectedSheet to false\r\n\tselectedSheet.getRange(\"F:F\").setColumnHidden(false);\r\n\t// Clear auto filter on selectedSheet\r\n\tselectedSheet.getAutoFilter().clearCriteria();\r\n\t// Set fill color to #16365C for range A1:E1 on selectedSheet\r\n\tselectedSheet.getRange(\"A1:E1\").getFormat().getFill().setColor(\"#16365C\");\r\n\t// Set range A1 on selectedSheet\r\n\tselectedSheet.getRange(\"A1\").setValue(\"Stores\");\r\n}","description":"","noCodeMetadata":"{\"intents\":[\"Unhide column(s) on J:J\",\"Unhide column(s) on B:B\",\"Unhide column(s) on E:E\",\"Unhide column(s) on I:I\",\"Unhide column(s) on H:H\",\"Unhide column(s) on G:G\",\"Unhide column(s) on G:G\",\"Unhide column(s) on E:E\",\"Unhide column(s) on F:F\",\"Clear filters on worksheet Sales\",\"Set background color to #16365C on A1:E1\",\"Set cell A1 to Stores\"]}","parameterInfo":null,"apiInfo":"{\"variant\":\"synchronous\",\"variantVersion\":2}"}